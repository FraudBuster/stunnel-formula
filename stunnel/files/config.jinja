# THIS FILE IS MANAGED BY SALT. DO NOT EDIT DIRECTLY
{% from "stunnel/map.jinja" import stunnel with context -%}

{% if stunnel.use_chroot %}
chroot = {{ stunnel.home }}
# relative to chroot
pid = /stunnel.pid
{% else %}
pid = {{ stunnel.pid_dir }}/stunnel.pid
{% endif %}

foreground = yes
# Required for to run as a native systemd service
# The default service is 'stunnel@stunnel.service'
# 'stunnel4.service' that is build from sysv init script is DEPRECATED.
# It was no longer automatically enabled since version 3:5.56+dfsg-7
# And was fully DEPRECATED in version 3:5.72-3

setuid = {{ stunnel.user }}
setgid = {{ stunnel.group }}

debug = {{ stunnel.get('debug', 'notice') }}

include = {{ stunnel.conf_dir }}/conf.d
include = {{ stunnel.conf_dir }}/services.d
